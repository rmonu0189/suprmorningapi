APP_ENV=development
APP_DEBUG=true
APP_URL=http://localhost

DB_HOST=127.0.0.1
DB_PORT=3306
DB_NAME=suprmorning
DB_USER=root
DB_PASS=secret

JWT_SECRET=replace_with_long_random_secret
JWT_ISSUER=suprmorning-api
JWT_AUDIENCE=suprmorning-clients
JWT_ACCESS_TTL_SECONDS=900
JWT_TTL_SECONDS=3600
JWT_REFRESH_TTL_SECONDS=2592000

# Phone OTP (passwordless). Codes are logged to storage/logs/otp.log when OTP_LOG_TO_FILE is not "false".
OTP_LENGTH=6
OTP_TTL_SECONDS=600
OTP_MAX_ATTEMPTS=5
OTP_LOG_TO_FILE=true
# NEVER enable in production — exposes the code in JSON for local testing only.
OTP_RETURN_CODE_IN_RESPONSE=false

# CORS: "*" or comma-separated origins
CORS_ALLOW_ORIGINS=*
CORS_ALLOW_CREDENTIALS=false
