APP_ENV=development
# When true, JSON may include "detail" on some errors. Unhandled exceptions + order placement failures are always appended to storage/logs/app.log.
APP_DEBUG=true
APP_URL=http://localhost

DB_HOST=127.0.0.1
DB_PORT=3306
DB_NAME=suprmorning
DB_USER=root
DB_PASS=secret

JWT_SECRET=ca050b61db3c3602cd745c7c2e4660c396981747f85e8c40a58060bef13f04f6
JWT_ISSUER=suprmorning-api
JWT_AUDIENCE=suprmorning-clients
JWT_ACCESS_TTL_SECONDS=900
JWT_TTL_SECONDS=3600
JWT_REFRESH_TTL_SECONDS=2592000

# Phone OTP (passwordless). Codes are logged to storage/logs/otp.log when OTP_LOG_TO_FILE is not "false".
OTP_LENGTH=6
OTP_TTL_SECONDS=600
OTP_MAX_ATTEMPTS=5
OTP_LOG_TO_FILE=true
# NEVER enable in production — exposes the code in JSON for local testing only.
OTP_RETURN_CODE_IN_RESPONSE=false

# Dev only: for listed phones (digits or +prefix), OTP is always OTP_TEST_CODE instead of random.
# Must match OTP_LENGTH (default 6). NEVER set OTP_ENABLE_FIXED_TEST_OTP=true in production.
OTP_ENABLE_FIXED_TEST_OTP=false
OTP_TEST_CODE=123456
OTP_TEST_PHONES=919109322140,918368178522

# CORS: "*" or comma-separated origins
CORS_ALLOW_ORIGINS=https://suprmorning.ggnproperty.com,http://localhost:3000,http://localhost:8081
CORS_ALLOW_CREDENTIALS=false

# Razorpay (orders + webhook). Key secret must never ship in the mobile app.
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=
# Dashboard → Webhooks → signing secret (for POST /v1/webhooks/razorpay)
RAZORPAY_WEBHOOK_SECRET=

# Firebase Cloud Messaging (Modern HTTP v1 API)
# Path to your Google Service Account JSON file (e.g., storage/firebase-service-account.json)
FIREBASE_SERVICE_ACCOUNT_JSON=storage/firebase/firebase-service-account.json
